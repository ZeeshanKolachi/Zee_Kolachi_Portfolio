# Copy this file to .env.local and fill in your keys.

# --- AI assistant (server-side, never exposed to the browser) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Contact form (optional) ---
# Create a free form at https://formspree.io and paste its id (the part after /f/).
# If left unset, the contact form gracefully falls back to opening a prefilled email.
NEXT_PUBLIC_FORMSPREE_ID=
